# IKSHAN BACKEND - Environment Configuration
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# -- Database (required for full app; task stream + OTP fallback use Postgres) --
# Use one of: DATABASE_URL, or DATABASE_TARGET + DATABASE_URL_LOCAL / _DEV / _PROD
DATABASE_URL=postgresql://USER:PASSWORD@localhost:5432/ikshan

# -- Task stream (SSE) persistence: postgres | redis --
# Default postgres. Set REDIS_URL only if you use TASKSTREAM_BACKEND=redis.
TASKSTREAM_BACKEND=postgres

# -- Redis (optional) --
# Leave unset or empty to skip Redis entirely (auth cache skipped; OTP uses otp_sessions table).
# REDIS_URL=redis://localhost:6379/0

# -- Application --
ENVIRONMENT=development
LOG_LEVEL=INFO
HOST=0.0.0.0
PORT=8000

# -- CORS --
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000","http://localhost:3001"]

# -- OpenAI --
OPENAI_API_KEY=your-openai-api-key-here
OPENAI_API_KEY_2=your-secondary-openai-key-here
OPENAI_MODEL_NAME=gpt-4o-mini

# -- SERP API --
SERP_API_KEY=your-serp-api-key-here

# -- JusPay (HDFC SmartGateway) --
# Local + dev Cloud Run: UAT host + sandbox (see env.development.json). Prod: env.production.json.
# JUSPAY_API_KEY / JUSPAY_RESPONSE_KEY must match the host (UAT keys for hdfcuat, prod keys for hdfc).
JUSPAY_MERCHANT_ID=your-merchant-id
JUSPAY_PAYMENT_PAGE_CLIENT_ID=hdfcmaster
JUSPAY_BASE_URL=https://smartgateway.hdfcuat.bank.in
JUSPAY_ENVIRONMENT=sandbox
JUSPAY_API_KEY=your-uat-or-prod-server-api-key
JUSPAY_RESPONSE_KEY=your-uat-or-prod-response-key

# -- Google Sheets --
GOOGLE_SHEETS_WEBHOOK_URL=your-google-sheets-webhook-url

# -- 2Factor.in OTP --
TWO_FACTOR_API_KEY=your-2factor-api-key-here

# -- Rate Limiting --
RATE_LIMIT_CHAT=10/minute
RATE_LIMIT_COMPANIES=30/minute
RATE_LIMIT_SPEAK=5/minute
RATE_LIMIT_DEFAULT=60/minute


OPENROUTER_API_KEY=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


