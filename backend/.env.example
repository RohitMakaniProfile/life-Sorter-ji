# IKSHAN BACKEND - Environment Configuration
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# Never commit .env — it is gitignored.

# -- Database (required — onboarding/chat fail without it) --
# Start Postgres locally, e.g. from repo root:  docker compose up -d postgres
# Then use (matches docker-compose postgres service):
#   DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ikshan
# Or: DATABASE_URL, or DATABASE_TARGET + DATABASE_URL_LOCAL / _DEV / _PROD
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ikshan

# -- Task stream (SSE) persistence: postgres | redis --
# Default postgres. Set REDIS_URL only if you use TASKSTREAM_BACKEND=redis.
TASKSTREAM_BACKEND=postgres

# -- Redis (optional) --
# Leave unset or empty to skip Redis entirely (auth cache skipped; OTP uses otp_sessions table).
# REDIS_URL=redis://localhost:6379/0

# -- Application --
ENVIRONMENT=development
LOG_LEVEL=INFO
HOST=0.0.0.0
PORT=8000

# -- CORS (include every host:port you open the app with, e.g. 127.0.0.1 vs localhost) --
CORS_ORIGINS=["http://localhost:5173","http://localhost:5174","http://localhost:5175","http://127.0.0.1:5173","http://127.0.0.1:5174","http://127.0.0.1:5175","http://localhost:3000","http://localhost:3001"]

# -- OpenAI --
OPENAI_API_KEY=your-openai-api-key-here
OPENAI_API_KEY_2=your-secondary-openai-key-here
OPENAI_MODEL_NAME=gpt-4o-mini

# -- SERP API --
SERP_API_KEY=your-serp-api-key-here

# -- JusPay (HDFC SmartGateway) —
# Keys must match JUSPAY_BASE_URL / environment (sandbox vs production).
JUSPAY_MERCHANT_ID=your-merchant-id
JUSPAY_PAYMENT_PAGE_CLIENT_ID=hdfcmaster
JUSPAY_BASE_URL=https://smartgateway.hdfcuat.bank.in
JUSPAY_ENVIRONMENT=sandbox
JUSPAY_API_KEY=your-juspay-api-key
JUSPAY_RESPONSE_KEY=your-juspay-response-key

# JusPay sandbox test card (local/dev only)
JUSPAY_TEST_CARD_NUMBER=4111111111111111
JUSPAY_TEST_CARD_EXPIRY=12/30
JUSPAY_TEST_CARD_CVV=123
JUSPAY_TEST_CARD_OTP=123456

# -- Google Sheets --
GOOGLE_SHEETS_WEBHOOK_URL=your-google-sheets-webhook-url

# -- 2Factor.in OTP --
TWO_FACTOR_API_KEY=your-2factor-api-key-here

# -- Rate limiting --
RATE_LIMIT_CHAT=10/minute
RATE_LIMIT_COMPANIES=30/minute
RATE_LIMIT_SPEAK=5/minute
RATE_LIMIT_DEFAULT=60/minute

# -- OpenRouter (optional) --
OPENROUTER_API_KEY=your-openrouter-api-key-here

# -- JWT (use a long random secret; do not reuse OAuth client secrets) --
# JWT_SECRET_KEY=change-me-generate-with-openssl-rand-hex-32

# -- Local scraper (optional; docker compose exposes scraper on host 8082 → 8081) --
# SCRAPER_BASE_URL=http://localhost:8082

# -- Skills subprocess (optional) --
# PYTHON_BIN=/path/to/backend/.venv/bin/python
